{
  "name": "landingpage-react-template",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "clean:deps": "rm -rf node_modules package-lock.json yarn.lock",
    "reinstall:clean": "npm run clean:deps && npm install",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "node scripts/lint.mjs",
    "format": "node scripts/format-code.mjs --write",
    "format:check": "node scripts/format-code.mjs --check",
    "test": "node scripts/run-tests.mjs",
    "test:coverage": "node scripts/run-tests.mjs --coverage",
    "coverage:check": "node scripts/check-coverage.mjs",
    "validate:code": "node scripts/validate-code.mjs",
    "autofix": "node scripts/autofix.mjs"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "5.1.4",
    "vite": "7.3.1"
  },
  "engines": {
    "node": "20.x"
  }
}
